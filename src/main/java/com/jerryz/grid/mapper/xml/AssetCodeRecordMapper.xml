<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jerryz.grid.mapper.AssetCodeRecordMapper">

    <select id="selectByAssetCode" resultType="com.jerryz.grid.pojo.po.AssetCodeRecord">
        SELECT *
        FROM asset_code_record
        WHERE asset_code = #{assetCode}
        LIMIT 1
    </select>

    <select id="selectList" resultType="com.jerryz.grid.pojo.po.AssetCodeRecord">
        SELECT *
        FROM asset_code_record
        <where>
            <if test="keyword != null and keyword != ''">
                (asset_code LIKE CONCAT('%', #{keyword}, '%') OR asset_name LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

</mapper>
